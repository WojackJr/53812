{
    "version": "2.0.0",
    "configurations": [
        {
            "name": "Ejecutar Analizador (Node.js)",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/Analizador/index.js",
            "cwd": "${workspaceFolder}/Analizador",
            "console": "internalConsole",
            "internalConsoleOptions": "openOnSessionStart",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Debug ANTLR4 grammar",
            "type": "antlr-debug",
            "request": "launch",
            "input": "${workspaceFolder}/Analizador/input.txt",
            "grammar": "${workspaceFolder}/Analizador/Calculator.g4",
            "printParseTree": true,
            "visualParseTree": true
        }
    ]
}
